# =============================================================================
# Clerk Authentication (Required)
# =============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk JWT template for backend auth
CLERK_JWT_TEMPLATE=oddish

# =============================================================================
# Backend Configuration
# =============================================================================
# Switch between 'local' and 'modal' backends
NEXT_PUBLIC_BACKEND_TYPE=modal

# Local FastAPI URL (used when BACKEND_TYPE=local)
FASTAPI_URL=http://localhost:8000

# Modal Configuration (used when BACKEND_TYPE=modal)
# Just the workspace prefix - the code appends --api.modal.run
NEXT_PUBLIC_MODAL_BASE_URL=https://your-workspace

# Set to "dev" for dev endpoints (adds -dev suffix), or "prod" for production endpoints
NEXT_PUBLIC_MODAL_ENV=prod

# Optional: Override individual Modal endpoint URLs if needed
# NEXT_PUBLIC_MODAL_API_URL=https://your-workspace-12345--api.modal.run

# =============================================================================
# Optional App & Clerk Redirect Overrides
# =============================================================================
# App base URL for absolute Clerk redirects (useful for local HTTPS flows)
# NEXT_PUBLIC_APP_URL=https://local.oddish.app
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
